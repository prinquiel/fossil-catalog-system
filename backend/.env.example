# Server
PORT=5001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fossil_catalog
DB_USER=fossil_admin
DB_PASSWORD=CAMBIAR_ESTO

# JWT
JWT_SECRET=CAMBIAR_ESTO_POR_ALGO_SECRETO
JWT_EXPIRE=7d

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# URLs
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5001

# Correo (aprobación de registros; opcional en desarrollo)
APP_NAME=Sistema de Catalogación de Fósiles
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Sistema Fósiles <noreply@ejemplo.com>"
