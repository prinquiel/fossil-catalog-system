# Server
PORT=5001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fossil_catalog
DB_USER=fossil_admin
DB_PASSWORD=CAMBIAR_ESTO

# JWT
JWT_SECRET=CAMBIAR_ESTO_POR_ALGO_SECRETO
JWT_EXPIRE=7d

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# URLs (Vite: 5173 por defecto; si esta ocupado usa 5174+. En desarrollo el backend acepta cualquier localhost.)
# URLs (frontend). Vite=5173, CRA=3000. Varias: CLIENT_URL=http://localhost:5173,http://localhost:3000
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5001

# Correo (aprobación de registros)
APP_NAME=Sistema de Catalogación de Fósiles
EMAIL_FROM="Sistema Fósiles <noreply@ejemplo.com>"

# --- Opción A: Mailpit local (recomendado en desarrollo) ---
# En la raíz del repo: docker compose -f docker-compose.mailpit.yml up -d
# Bandeja entrante: http://localhost:8025
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_NO_AUTH=true

# --- Opción B: proveedor SMTP con usuario/contraseña (Gmail, SendGrid, etc.) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_NO_AUTH=false
# SMTP_USER=tu_cuenta@gmail.com
# SMTP_PASS=contraseña_de_aplicacion

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_NO_AUTH=false
SMTP_USER=
SMTP_PASS=
